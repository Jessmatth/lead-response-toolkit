{
  "name": "lead-response-automater",
  "version": "0.1.0",
  "description": "Webhook service that responds to new web-form leads: AI qualification + routing, Google Sheets logging, personalized auto-reply, and internal team notification.",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test:lead": "tsx scripts/send-test-lead.ts",
    "test:qualify": "tsx scripts/test-qualify.ts",
    "auth:google": "tsx scripts/google-auth-setup.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "googleapis": "^144.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
