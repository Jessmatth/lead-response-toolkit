# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# ── Anthropic (Claude) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model used for qualification + the personalized email intro.
CLAUDE_MODEL=claude-opus-4-8

# ── Lead magnet ──────────────────────────────────────────────────────────
# The URL every lead receives by email (your public GitHub repo).
GITHUB_REPO_URL=https://github.com/yourname/lead-response-automater
# Subject line of the delivery email.
MAGNET_EMAIL_SUBJECT=Your lead-response automation files are inside 👇

# ── Google (Sheets + Gmail) via personal-Gmail OAuth ─────────────────────
# Local dev: point these at the files on disk.
GOOGLE_OAUTH_CLIENT_FILE=./oauth-client.json
GOOGLE_TOKEN_FILE=./token.json
# Hosted (e.g. Replit): instead of files, paste the raw JSON contents here.
# If set, these take priority over the file paths above.
# GOOGLE_OAUTH_CLIENT_JSON={"installed":{...}}
# GOOGLE_TOKEN_JSON={"access_token":"...","refresh_token":"..."}

# Spreadsheet ID (the long id in the Sheet URL) leads get appended to.
LEADS_SHEET_ID=
# Tab/range to append to (tab must exist — rename Sheet1 to "Leads" or change this).
LEADS_SHEET_RANGE=Leads!A:Z

# The Gmail address you authorized — appears as the From on outgoing mail.
GMAIL_SENDER=you@gmail.com
# Friendly From name + email sign-off.
REPLY_FROM_NAME=Your Name
# Internal address(es) that get the new-lead notification (comma-separated).
TEAM_NOTIFY_TO=you@gmail.com

# ── Business context (feeds the AI qualification prompt) ─────────────────
COMPANY_NAME=Your Name / Brand
COMPANY_DESCRIPTION=One or two sentences on what you sell and who your ideal customer is.
